<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ReelsGuard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <!-- Blocker screen: dark, immersive, no action bar -->
    <style name="Theme.ReelsGuard.Blocker" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/blocker_accent</item>
        <item name="android:statusBarColor">@color/blocker_bg</item>
        <item name="android:navigationBarColor">@color/blocker_bg</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
