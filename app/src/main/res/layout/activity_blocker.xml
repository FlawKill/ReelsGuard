<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/blocker_bg">

    <!-- Emoji / Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🧘"
        android:textSize="72sp"
        android:layout_marginBottom="24dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Take a Break"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/blocker_text_primary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You've watched Reels for your set limit today.\n\nTime to rest your eyes and recharge."
        android:textSize="16sp"
        android:textColor="@color/blocker_text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="48dp" />

    <!-- Countdown card -->
    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/countdown_bg"
        android:padding="24dp"
        android:layout_marginBottom="48dp">

        <TextView
            android:id="@+id/tvBreakLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Break ends in:"
            android:textSize="13sp"
            android:textColor="@color/blocker_text_secondary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="@color/blocker_accent"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Tips -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Try: stretching, drinking water, or looking at something 20 feet away for 20 seconds."
        android:textSize="13sp"
        android:textColor="@color/blocker_text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="32dp" />

    <!-- Go home button -->
    <Button
        android:id="@+id/btnGoHome"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Go to Home Screen"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:backgroundTint="@color/blocker_accent"
        style="@style/Widget.Material3.Button" />

</LinearLayout>
